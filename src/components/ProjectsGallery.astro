---
const {
  product = "imituil"
} = Astro.props;

const galleries = {
  imituil: {
    eyebrow: "RÉALISATIONS",

    title: "Découvrez quelques réalisations en tôle imitation tuile",

    introduction:
      "Nos tôles imitation tuile fabriquées sur mesure équipent aussi bien des abris de jardin, garages, carports, chalets que des bâtiments résidentiels ou agricoles. Découvrez quelques réalisations illustrant la qualité de nos profils, de nos finitions et de nos accessoires.",

    featured: {
      image:
        "/images/realisations/tole-imitation-tuile/toiture-tole-imitation-tuile-ral-8004.jpg",
      alt: "Toiture en tôle imitation tuile RAL 8004 mat texturé",
      title: "Toiture imitation tuile RAL 8004 mat texturé",
      description:
        "Couverture fabriquée sur mesure avec accessoires assortis, comprenant faîtage, rives et visserie laquée pour une finition homogène et durable."
    },

    projects: [
      {
        image:
          "/images/realisations/tole-imitation-tuile/toiture-tole-imitation-tuile-ral-7024.jpg",
        alt: "Toiture d'abri de jardin en tôle imitation tuile RAL 7024",
        title: "Abri de jardin",
        finish: "RAL 7024 mat texturé"
      },
      {
        image:
          "/images/realisations/tole-imitation-tuile/carport-tole-imitation-tuile-ral-8004.jpg",
        alt: "Carport bois avec toiture en tôle imitation tuile RAL 8004",
        title: "Carport bois",
        finish: "RAL 8004 mat texturé"
      },
      {
        image:
          "/images/realisations/tole-imitation-tuile/chalet-bois-tole-imitation-tuile-ral-9005.jpg",
        alt: "Chalet bois avec toiture en tôle imitation tuile RAL 9005",
        title: "Chalet bois",
        finish: "RAL 9005 mat texturé"
      },
      {
        image:
          "/images/realisations/tole-imitation-tuile/abri-bois-tole-imitation-tuile-ral-6020.jpg",
        alt: "Abri bois avec toiture en tôle imitation tuile RAL 6020",
        title: "Abri bois",
        finish: "RAL 6020 mat texturé"
      }
    ],

    footerTitle: "Vous avez un projet similaire ?",

    footerText:
      "Chaque toiture est fabriquée sur mesure dans notre atelier de Marsac-sur-l'Isle selon les dimensions de votre chantier. Nous proposons plusieurs coloris, des accessoires assortis et une fabrication rapide pour les professionnels."
  }
};

const gallery = galleries[product];
---

{gallery && (
  <section id="realisations" class="section projects-gallery">
    <div class="container">

      <div class="section-heading">
        <span class="eyebrow">{gallery.eyebrow}</span>

        <h2>{gallery.title}</h2>

        <p>{gallery.introduction}</p>
      </div>

      <div class="gallery-grid">

        <article class="gallery-feature">
          <img
            src={gallery.featured.image}
            alt={gallery.featured.alt}
            loading="lazy"
            width="1600"
            height="900"
          />

          <div class="gallery-content">
            <span class="gallery-badge">Projet réalisé</span>

            <h3>{gallery.featured.title}</h3>

            <p>{gallery.featured.description}</p>
          </div>
        </article>

        {gallery.projects.map((project) => (
          <article class="gallery-card">
            <img
              src={project.image}
              alt={project.alt}
              loading="lazy"
              width="800"
              height="600"
            />

            <div class="gallery-card-content">
              <h3>{project.title}</h3>
              <p>{project.finish}</p>
            </div>
          </article>
        ))}

      </div>

      <div class="gallery-footer">
        <div>
          <h3>{gallery.footerTitle}</h3>
          <p>{gallery.footerText}</p>
        </div>

        <a href="/realisations" class="btn btn-outline">
          Voir toutes nos réalisations
        </a>
      </div>

    </div>
  </section>
)}
