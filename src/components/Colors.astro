<section class="section soft">
  <div class="container">
    <span class="eyebrow">Nuancier professionnel</span>
    <h2 class="title">Couleurs et finitions disponibles</h2>
    <p class="lead">
      Découvrez notre gamme de coloris disponibles en stock ou sur commande pour le bardage acier,
      la couverture industrielle et les tôles imitation tuile.
    </p>

    <div class="availability-box">
      <p><span class="dot stock"></span><strong>Disponible immédiatement :</strong> références tenues en stock permanent, fabrication généralement sous 24/48 h.</p>
      <p><span class="dot order"></span><strong>Sur commande :</strong> références disponibles selon quantités et délais fournisseurs.</p>
    </div>

    <div class="finish-block">
      <h3>Finition brillante</h3>

      <h4>Épaisseur 0,70 mm</h4>
      <div class="grid colors">
        <ColorCard ral="RAL 9002" finish="Brillant" ep="0,70 mm" status="stock" color="#ecebe2" />
        <ColorCard ral="RAL 9006" finish="Brillant" ep="0,70 mm" status="stock" color="#a7a8a5" />
      </div>

      <h4>Épaisseur 0,60 mm</h4>
      <div class="grid colors">
        <ColorCard ral="RAL 9002" finish="Brillant" ep="0,60 mm" status="stock" color="#ecebe2" />
        <ColorCard ral="RAL 7016" finish="Brillant" ep="0,60 mm" status="stock" color="#383e42" />
      </div>

      <h4>Épaisseur 0,50 mm</h4>
      <div class="grid colors">
        <ColorCard ral="RAL 3005" finish="Brillant" ep="0,50 mm" status="order" color="#5e2028" />
        <ColorCard ral="RAL 3009" finish="Brillant" ep="0,50 mm" status="order" color="#642424" />
        <ColorCard ral="RAL 3011" finish="Brillant" ep="0,50 mm" status="order" color="#781f19" />
        <ColorCard ral="RAL 5010" finish="Brillant" ep="0,50 mm" status="order" color="#004f7c" />
        <ColorCard ral="RAL 6005" finish="Brillant" ep="0,50 mm" status="order" color="#114232" />
        <ColorCard ral="RAL 7016" finish="Brillant" ep="0,50 mm" status="order" color="#383e42" />
        <ColorCard ral="RAL 7024" finish="Brillant" ep="0,50 mm" status="order" color="#50565c" />
        <ColorCard ral="RAL 8004" finish="Brillant" ep="0,50 mm" status="order" color="#8f3d1f" />
        <ColorCard ral="RAL 8017" finish="Brillant" ep="0,50 mm" status="order" color="#44322d" />
        <ColorCard ral="RAL 9002" finish="Brillant" ep="0,50 mm" status="order" color="#ecebe2" />
        <ColorCard ral="RAL 9005" finish="Brillant" ep="0,50 mm" status="order" color="#050505" />
        <ColorCard ral="RAL 9006" finish="Brillant" ep="0,50 mm" status="order" color="#a7a8a5" />
      </div>
    </div>

    <div class="finish-block">
      <h3>Finition mate texturée</h3>

      <h4>Épaisseur 0,60 mm</h4>
      <div class="grid colors">
        <ColorCard ral="RAL 3005" finish="Mat texturé" ep="0,60 mm" status="order" color="#5e2028" />
        <ColorCard ral="RAL 8017" finish="Mat texturé" ep="0,60 mm" status="order" color="#44322d" />
        <ColorCard ral="RAL 8019" finish="Mat texturé" ep="0,60 mm" status="order" color="#3b332f" />
        <ColorCard ral="RAL 9005" finish="Mat texturé" ep="0,60 mm" status="order" color="#050505" />
      </div>

      <h4>Épaisseur 0,50 mm</h4>
      <div class="grid colors">
        <ColorCard ral="RAL 3005" finish="Mat texturé" ep="0,50 mm" status="stock" color="#5e2028" />
        <ColorCard ral="RAL 3009" finish="Mat texturé" ep="0,50 mm" status="stock" color="#642424" />
        <ColorCard ral="RAL 6020" finish="Mat texturé" ep="0,50 mm" status="stock" color="#2f4934" />
        <ColorCard ral="RAL 7016" finish="Mat texturé" ep="0,50 mm" status="stock" color="#383e42" />
        <ColorCard ral="RAL 7024" finish="Mat texturé" ep="0,50 mm" status="stock" color="#50565c" />
        <ColorCard ral="RAL 8004" finish="Mat texturé" ep="0,50 mm" status="stock" color="#8f3d1f" />
        <ColorCard ral="RAL 8017" finish="Mat texturé" ep="0,50 mm" status="stock" color="#44322d" />
        <ColorCard ral="RAL 8019" finish="Mat texturé" ep="0,50 mm" status="stock" color="#3b332f" />
        <ColorCard ral="RAL 9005" finish="Mat texturé" ep="0,50 mm" status="stock" color="#050505" />
      </div>
    </div>

    <div class="finish-block">
      <h3>Finition imitation bois</h3>

      <h4>Épaisseur 0,50 mm</h4>
      <div class="grid colors">
        <ColorCard ral="Bois noir" finish="Imitation bois" ep="0,50 mm" status="order" color="#1d1a17" />
      </div>

      <h4>Épaisseur 0,45 mm</h4>
      <div class="grid colors">
        <ColorCard ral="Chêne clair" finish="Imitation bois" ep="0,45 mm" status="stock" image="/images/chene-clair.png" />
        <ColorCard ral="Chêne foncé" finish="Imitation bois" ep="0,45 mm" status="stock" color="#7b4a25" />
      </div>
    </div>

    <p class="lead" style="margin-top:34px;font-size:.98rem">
      Vous recherchez un autre coloris ? De nombreuses références RAL sont disponibles sur demande selon les quantités et les possibilités d’approvisionnement.
    </p>
  </div>
</section>

---
const ColorCard = ({ ral, finish, ep, status, color, image }) => (
  <div class="card color-card">
    <div class="swatch" style={color ? `--sw:${color}` : ""}>
      {image && <img src={image} alt={`Finition acier ${ral} ${finish} Marin Profils`} loading="lazy" />}
    </div>
    <h3>
      <span class={`dot ${status === "stock" ? "stock" : "order"}`}></span>
      {ral}
    </h3>
    <p>{finish} · {ep}</p>
  </div>
);
---
