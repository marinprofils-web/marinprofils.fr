---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact | Marin Profils" description="Contactez Marin Profils pour une demande de devis professionnel en tôles acier, couverture et bardage.">
  <section class="page-hero"><div class="container"><span class="eyebrow" style="color:white">Contact</span><h1 class="title">Demande de devis professionnel</h1><p class="lead">Marin Profils travaille exclusivement avec les professionnels. Les particuliers sont orientés vers le site dédié tôle imitation tuile.</p></div></section>
  <section class="section"><div class="container grid contact-grid">
    <form class="card form" style="padding:28px" name="contact" method="post" data-netlify="true">
      <input type="hidden" name="form-name" value="contact" />
      <input name="entreprise" placeholder="Entreprise" required />
      <input name="nom" placeholder="Nom / contact" required />
      <input type="email" name="email" placeholder="Email" required />
      <input name="telephone" placeholder="Téléphone" />
      <select name="produit"><option>Produit concerné</option><option>Tôle imitation tuile</option><option>Bac acier</option><option>Bardage</option><option>Accessoires</option></select>
      <textarea name="message" placeholder="Longueurs, quantités, couleur, lieu de livraison..."></textarea>
      <button class="btn primary" type="submit">Envoyer la demande</button>
    </form>
    <div class="card" style="padding:34px"><h2 class="title" style="font-size:2.1rem">Marin Profils</h2><p class="lead">Fabricant de profils acier en Dordogne pour professionnels du bâtiment, négoces et industriels.</p><div class="map">Carte / coordonnées à compléter</div><p><strong>Particulier ?</strong><br/>Rendez-vous sur le site dédié : tole-imitation-tuile.fr</p></div>
  </div></section>
</Layout>
