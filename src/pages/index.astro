---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import Products from '../components/Products.astro';
import Manufacturing from '../components/Manufacturing.astro';
import Process from '../components/Process.astro';
import Colors from '../components/Colors.astro';
import CTA from '../components/CTA.astro';
---
<Layout>
  <Hero />
  <Stats />
  <Manufacturing />
  <Products />
  <Process />
  <Colors />
  <section class="section">
    <div class="container grid two">
      <div>
        <p class="kicker">Professionnels uniquement</p>
        <h2>Un site pensé pour les artisans, négoces et industriels</h2>
      </div>
      <div>
        <p class="lead">Marin Profils travaille exclusivement avec les professionnels. Les particuliers sont orientés vers le site dédié à la vente en ligne de tôles imitation tuile.</p>
        <a class="btn ghost" href="https://tole-imitation-tuile.fr">Site particuliers</a>
      </div>
    </div>
  </section>
  <CTA />
</Layout>
