---
import Layout from '../layouts/Layout.astro'; import Products from '../components/Products.astro'; import CTA from '../components/CTA.astro';
---
<Layout title="Produits | Marin Profils" description="Tôles imitation tuile, bacs acier, bardages et accessoires acier sur mesure pour les professionnels.">
  <section class="page-hero"><div class="container"><span class="eyebrow" style="color:white">Produits</span><h1 class="title">Profils acier pour couverture et bardage</h1><p class="lead">Une gamme orientée professionnels : fabrication sur mesure, stock permanent et accessoires adaptés.</p></div></section>
  <Products />
  <section class="section"><div class="container grid" style="grid-template-columns:repeat(2,1fr)">
    <div class="card step"><h2>Tôle imitation tuile</h2><p>Solution esthétique pour toiture avec relief imitation tuile. Disponible en finitions mat texturé selon stock.</p></div>
    <div class="card step"><h2>Bac acier</h2><p>Profil de couverture industrielle pour bâtiments professionnels, agricoles et techniques.</p></div>
    <div class="card step"><h2>Bardage acier</h2><p>Habillage de façades en acier prélaqué, disponible en finitions mates, brillantes et aspect bois.</p></div>
    <div class="card step"><h2>Accessoires</h2><p>Faîtages, rives, closoirs, visserie et pièces de finition pour assurer une pose complète.</p></div>
  </div></section>
  <CTA />
</Layout>
