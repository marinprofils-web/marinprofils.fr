---
import Layout from '../layouts/Layout.astro'; import Products from '../components/Products.astro'; import CTA from '../components/CTA.astro';
---
<Layout title="Produits | Marin Profils" description="Tôles imitation tuile, bacs acier, bardages et accessoires acier sur mesure pour les professionnels.">
  <section class="page-hero"><div class="container"><span class="eyebrow" style="color:white">Produits</span><h1 class="title">Nos solutions acier pour la couverture et le bardage</h1><p class="lead">Fabricant français de tôles acier sur mesure pour les professionnels. Découvrez notre gamme de tôles imitation tuile, bacs acier, bardages et accessoires de finition.</p></div></section>
  <Products />
  <section class="section"><div class="container grid" style="grid-template-columns:repeat(2,1fr)">
    <div class="card step"><h2>Tôle imitation tuile</h2><p>Aspect traditionnel • Fabrication sur mesure</p></div>
    <div class="card step"><h2>Bac acier</h2><p>Toiture industrielle et agricole.</p></div>
    <div class="card step"><h2>Bardage acier</h2><p>Bardage vertical et horizontal.</p></div>
    <div class="card step"><h2>Accessoires</h2><p>Faîtages • Rives • Visserie • Closoirs • ...</p></div>
  </div></section>
  <CTA />
</Layout>
