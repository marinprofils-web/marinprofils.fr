---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Demande envoyée | Marin Profils"
  description="Votre demande de devis a bien été transmise à Marin Profils."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow" style="color:white">Message envoyé</span>

      <h1 class="title">
        Merci pour votre demande
      </h1>

      <p class="lead">
        Votre demande de devis a bien été transmise à Marin Profils.
        Nous vous répondrons dans les meilleurs délais.
      </p>

      <a class="btn light" href="/">
        Retour à l’accueil
      </a>
    </div>
  </section>
</Layout>
