---
import Layout from '../../layouts/Layout.astro';
import WhyMarin from '../../components/WhyMarin.astro';
import FAQ from '../../components/FAQ.astro';
import CTA from '../../components/CTA.astro';
import Colors from '../../components/Colors.astro';
import ProjectsGallery from '../../components/ProjectsGallery.astro';
---

<Layout
  title="Bac acier de couverture sur mesure pour professionnels | Marin Profils"
  description="Fabricant français de bac acier de couverture sur mesure. Profil trapézoïdal, longueurs adaptées au chantier, plusieurs épaisseurs, coloris et option DRIPSTOP."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow" style="color:white">Fabricant français</span>
      <h1 class="title">Bac acier de couverture sur mesure pour les professionnels</h1>
      <p class="lead">
        Marin Profils fabrique en Dordogne des bacs acier trapézoïdaux de couverture,
        découpés à la longueur demandée. Une solution légère, résistante et rapide à
        poser pour les bâtiments agricoles, industriels, artisanaux et professionnels.
      </p>
    </div>
  </section>

  <section class="product-anchor-nav" aria-label="Navigation dans la page">
    <div class="container">
      <nav class="anchor-nav" aria-label="Navigation rapide">
        <div class="container anchor-nav-inner">
          <a href="#presentation" class="anchor-link"><span class="anchor-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 6h14M5 12h10M5 18h14" /></svg></span><span>Présentation</span></a>
          <a href="#avantages" class="anchor-link"><span class="anchor-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="m12 3 2.2 4.5 5 .7-3.6 3.5.9 5-4.5-2.4-4.5 2.4.9-5-3.6-3.5 5-.7L12 3Z" /></svg></span><span>Avantages</span></a>
          <a href="#caracteristiques" class="anchor-link"><span class="anchor-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 7h10M18 7h2M4 17h2M10 17h10M14 4v6M8 14v6" /></svg></span><span>Caractéristiques</span></a>
          <a href="#couleurs" class="anchor-link"><span class="anchor-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 3a9 9 0 1 0 0 18h1.5a2 2 0 0 0 0-4H12a2 2 0 0 1 0-4h3a6 6 0 0 0 0-12h-3Z" /><circle cx="7.5" cy="10" r="1" /><circle cx="10" cy="6.8" r="1" /><circle cx="14" cy="6.8" r="1" /></svg></span><span>Couleurs</span></a>
          <a href="#applications" class="anchor-link"><span class="anchor-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 11.5 12 4l9 7.5M5 10v10h14V10M9 20v-6h6v6" /></svg></span><span>Applications</span></a>
          <a href="#realisations" class="anchor-link"><span class="anchor-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2" /><path d="m7 15 3-3 2 2 3-4 3 5" /><circle cx="8" cy="9" r="1" /></svg></span><span>Réalisations</span></a>
          <a href="#guide-achat" class="anchor-link"><span class="anchor-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 4h11a3 3 0 0 1 3 3v13H8a3 3 0 0 1-3-3V4Z" /><path d="M8 4v13a3 3 0 0 0 3 3M9 8h6M9 12h6" /></svg></span><span>Guide d’achat</span></a>
          <a href="#faq" class="anchor-link"><span class="anchor-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" /><path d="M9.8 9a2.4 2.4 0 1 1 3.8 2c-1 .7-1.6 1.1-1.6 2.4M12 17h.01" /></svg></span><span>FAQ</span></a>
        </div>
      </nav>
    </div>
  </section>

  <section id="presentation" class="section">
    <div class="container split product-detail-intro">
      <div class="image-stack">
        <img src="/images/fabrication-bac-acier-couverture-sur-mesure.jpg" alt="Fabrication de bac acier de couverture sur mesure dans l'atelier Marin Profils" width="1200" height="900" loading="eager" />
      </div>
      <div>
        <span class="eyebrow">Fabrication sur mesure</span>
        <h2 class="title">Une couverture acier résistante, légère et rapide à poser</h2>
        <p class="lead">Le bac acier trapézoïdal constitue une solution efficace pour couvrir rapidement de grandes surfaces tout en limitant la charge appliquée à la charpente.</p>
        <p class="product-detail-text">Chaque bac acier est fabriqué à la longueur souhaitée afin de limiter les recoupes, de réduire les pertes de matière et de faciliter la pose. Notre fabrication standard couvre les longueurs de 0,80 m à 6,00 m, avec une possibilité jusqu’à 8,00 m selon les conditions de retrait ou de transport.</p>
        <a class="btn primary" href="/contact">Demander un devis</a>
      </div>
    </div>
  </section>

  <section id="avantages" class="section soft">
    <div class="container">
      <span class="eyebrow">Les avantages</span>
      <h2 class="title">Pourquoi choisir un bac acier de couverture ?</h2>
      <p class="lead">Le bac acier permet de couvrir rapidement des bâtiments de dimensions variées avec une solution fiable, économique et adaptée aux usages professionnels.</p>
      <div class="grid product-benefits">
        <article class="card product-benefit"><h3>Fabrication à la longueur</h3><p>Les panneaux sont produits selon les dimensions demandées afin de réduire les découpes, les chutes et le temps passé sur chantier.</p></article>
        <article class="card product-benefit"><h3>Pose rapide</h3><p>La grande largeur utile des panneaux permet de couvrir rapidement une toiture et de limiter le nombre d’éléments à manipuler.</p></article>
        <article class="card product-benefit"><h3>Faible poids</h3><p>Avec environ 4,2 kg/m² en épaisseur 0,50 mm, le bac acier limite les charges appliquées à la structure.</p></article>
        <article class="card product-benefit"><h3>Plusieurs épaisseurs</h3><p>Les épaisseurs disponibles de 0,45 mm à 0,70 mm permettent d’adapter le produit aux contraintes du bâtiment et à l’entraxe des appuis.</p></article>
        <article class="card product-benefit"><h3>Option anti-condensation</h3><p>Le feutre DRIPSTOP peut être appliqué sous la tôle afin de retenir temporairement l’humidité liée à la condensation.</p></article>
        <article class="card product-benefit"><h3>Accessoires assortis</h3><p>Faîtages, rives, solins, closoirs et visserie permettent de réaliser une couverture complète avec des finitions adaptées.</p></article>
      </div>
    </div>
  </section>

  <section id="caracteristiques" class="section">
    <div class="container">
      <span class="eyebrow">Caractéristiques techniques</span>
      <h2 class="title">Les principales données de notre bac acier de couverture</h2>
      <p class="lead">Nos bacs acier sont fabriqués sur mesure dans notre atelier de Marsac-sur-l’Isle, selon les dimensions et les contraintes de chaque chantier professionnel.</p>
      <div class="table-wrap">
        <table class="usage-table product-specifications">
          <tbody>
            <tr><th scope="row">Type de profil</th><td>Bac acier trapézoïdal de couverture</td></tr>
            <tr><th scope="row">Largeur totale</th><td>1 160 mm</td></tr>
            <tr><th scope="row">Largeur utile</th><td>1 100 mm</td></tr>
            <tr><th scope="row">Hauteur d’onde</th><td>20 mm</td></tr>
            <tr><th scope="row">Longueur de fabrication standard</th><td>De 0,80 m à 6,00 m</td></tr>
            <tr><th scope="row">Longueur exceptionnelle</th><td>Jusqu’à 8,00 m uniquement en cas de retrait par le client ou d’enlèvement par son propre transporteur</td></tr>
            <tr><th scope="row">Épaisseurs disponibles</th><td>De 0,45 mm à 0,70 mm</td></tr>
            <tr><th scope="row">Poids indicatif</th><td>Environ 4,2 kg/m² en épaisseur 0,50 mm</td></tr>
            <tr><th scope="row">Pente de toiture</th><td>Pente à déterminer conformément aux prescriptions du NF DTU 40.35, selon la configuration du bâtiment, la zone climatique, l’exposition et les éventuels recouvrements</td></tr>
            <tr><th scope="row">Option anti-condensation</th><td>Feutre DRIPSTOP disponible selon la configuration demandée</td></tr>
            <tr><th scope="row">Matériau</th><td>Acier galvanisé prélaqué, avec protection anticorrosion et finition selon le coloris choisi.</td></tr>
            <tr><th scope="row">Finitions</th><td>Finitions brillantes ou mates texturées selon les disponibilités et le coloris sélectionné.</td></tr>
            <tr><th scope="row">Applications</th><td>Bâtiments agricoles, bâtiments industriels, ateliers, entrepôts, garages, carports, dépendances et rénovation de toiture.</td></tr>
          </tbody>
        </table>
      </div>

      <div class="profile-schema">
        <h3>Dimensions du profil</h3>
        <img src="/images/profil-bac-acier-couverture.png" alt="Schéma technique du bac acier de couverture Marin Profils avec largeur utile de 1 100 mm, largeur totale de 1 160 mm et hauteur d'onde de 20 mm" width="940" height="520" loading="lazy" />
      </div>

      <div class="technical-note">
        <h3>Informations importantes pour la mise en œuvre</h3>
        <p>La pente minimale ne doit pas être définie par une valeur unique pour tous les chantiers. Elle doit être déterminée conformément au NF DTU 40.35, en tenant compte notamment de la zone climatique, de l’exposition du bâtiment, de la longueur du rampant et de la présence éventuelle de recouvrements transversaux.</p>
        <p>Les bacs acier sont fabriqués sur mesure de 0,80 m à 6,00 m. Une fabrication jusqu’à 8,00 m est possible uniquement lorsque le client retire la marchandise ou organise l’enlèvement avec son propre transporteur. Les grandes longueurs exigent des précautions particulières lors du transport, du déchargement et de la manipulation afin d’éviter les déformations.</p>
        <p>Le feutre DRIPSTOP retient temporairement l’humidité produite par la condensation, puis la restitue lorsque les conditions permettent son évaporation. Il ne remplace pas une ventilation correctement conçue de la sous-face de la couverture.</p>
      </div>
    </div>
  </section>

  <Colors product="all" />

  <section id="applications" class="section soft">
    <div class="container split">
      <div>
        <span class="eyebrow">Applications</span>
        <h2 class="title">Pour quels bâtiments utiliser un bac acier de couverture ?</h2>
        <p class="lead">Le bac acier convient à de nombreux projets nécessitant une couverture légère, résistante et rapide à mettre en œuvre.</p>
        <ul class="product-application-list">
          <li>Bâtiments agricoles</li><li>Hangars et stabulations</li><li>Bâtiments industriels</li><li>Ateliers et locaux artisanaux</li><li>Entrepôts et zones de stockage</li><li>Garages et carports</li><li>Dépendances et annexes</li><li>Rénovation de toitures</li>
        </ul>
      </div>
      <div class="card product-information-card">
        <h3>Une étude adaptée à chaque chantier</h3>
        <p>Avant toute commande, il est nécessaire de vérifier la pente, la charpente, l’entraxe des appuis, les charges climatiques, la ventilation et les accessoires de finition. Notre équipe peut vous aider à identifier les produits nécessaires à votre projet.</p>
        <a class="btn primary" href="/contact">Nous transmettre votre projet</a>
      </div>
    </div>
  </section>

  <ProjectsGallery product="bacacier" />

  <section class="section soft" id="guide-achat">
    <div class="container">
      <span class="eyebrow">Guide d’achat</span>
      <h2 class="title">Tout savoir sur le bac acier de couverture</h2>
      <p class="lead">Retrouvez les réponses aux principales questions que se posent les professionnels avant de choisir un bac acier pour une couverture neuve ou une rénovation.</p>
      <div class="faq">
        <details class="faq-item" open><summary>Pourquoi choisir un bac acier pour une couverture ?</summary><p>Le bac acier permet de couvrir rapidement de grandes surfaces tout en limitant le poids appliqué à la charpente. Sa largeur utile réduit le nombre de panneaux à poser et sa fabrication sur mesure permet d’adapter précisément les longueurs aux dimensions du chantier.</p></details>
        <details class="faq-item"><summary>Quelle pente minimale prévoir pour un bac acier ?</summary><p>La pente doit être déterminée conformément au NF DTU 40.35. Elle dépend notamment de la zone climatique, de l’exposition du bâtiment, de la longueur du rampant, du profil utilisé et de la présence éventuelle de recouvrements transversaux.</p></details>
        <details class="faq-item"><summary>Quelle épaisseur de bac acier choisir ?</summary><p>Le choix de l’épaisseur dépend de l’entraxe des pannes, des charges climatiques, de la longueur des panneaux et de l’usage du bâtiment. Notre gamme est disponible de 0,45 mm à 0,70 mm afin de répondre à différentes configurations de chantier.</p></details>
        <details class="faq-item"><summary>À quoi sert le feutre anti-condensation DRIPSTOP ?</summary><p>Le feutre DRIPSTOP retient temporairement les gouttelettes formées sous la tôle lorsque les conditions favorisent la condensation. Il restitue ensuite cette humidité par évaporation lorsque l’air se réchauffe et circule correctement. Une ventilation adaptée reste indispensable.</p></details>
        <details class="faq-item"><summary>Quelle portée prévoir entre les pannes ?</summary><p>La portée admissible dépend du profil, de l’épaisseur de la tôle, des charges de neige et de vent ainsi que des conditions d’appui. Elle doit être vérifiée pour chaque projet à partir des données techniques applicables et des contraintes du bâtiment.</p></details>
        <details class="faq-item"><summary>Quels accessoires sont nécessaires pour une pose complète ?</summary><p>Une couverture complète peut nécessiter des faîtages, rives, bordures, solins, closoirs, vis de fixation et pièces de raccordement. Le choix dépend de la forme de la toiture, des pénétrations, des raccords muraux et des finitions prévues.</p></details>
        <details class="faq-item"><summary>Quelle longueur de bac acier choisir ?</summary><p>Les panneaux sont fabriqués de 0,80 m à 6,00 m en standard. Les longueurs jusqu’à 8,00 m sont réservées aux commandes retirées par le client ou transportées par son propre prestataire. Plus les panneaux sont longs, plus leur manutention nécessite de précautions.</p></details>
        <details class="faq-item"><summary>Quelle est la durée de vie d’une couverture en bac acier ?</summary><p>La durabilité dépend de la qualité du revêtement, de l’environnement du bâtiment, de la ventilation, du respect des règles de pose et de l’entretien. Une couverture correctement conçue, posée et entretenue offre une solution durable pour de nombreux bâtiments.</p></details>
        <details class="faq-item"><summary>Le bac acier convient-il à une rénovation de toiture ?</summary><p>Oui, son faible poids peut être intéressant en rénovation, sous réserve que la charpente et les supports soient adaptés. Il convient de vérifier l’état de la structure, l’alignement des appuis, la ventilation, les fixations et les raccordements avant la pose.</p></details>
      </div>
    </div>
  </section>

  <WhyMarin />
  <FAQ title="Questions fréquentes sur le bac acier de couverture" lead="Retrouvez les réponses aux principales questions concernant nos bacs acier de couverture fabriqués sur mesure." />
  <CTA />
</Layout>
