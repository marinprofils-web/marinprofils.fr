---
import Layout from '../../layouts/Layout.astro';
import WhyMarin from '../../components/WhyMarin.astro';
import FAQ from '../../components/FAQ.astro';
import CTA from '../../components/CTA.astro';
---

<Layout
  title="Tôle imitation tuile sur mesure pour professionnels | Marin Profils"
  description="Fabricant français de tôles imitation tuile sur mesure en acier. Longueurs adaptées au chantier, plusieurs coloris et accessoires pour les professionnels."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow" style="color:white">
        Couverture acier
      </span>

      <h1 class="title">
        Tôle imitation tuile sur mesure pour les professionnels
      </h1>

      <p class="lead">
        Marin Profils fabrique en Dordogne des tôles imitation tuile en acier
        prélaqué, découpées à la longueur demandée. Une solution de couverture
        légère, esthétique, durable et rapide à mettre en œuvre pour les bâtiments résidentiels,
        artisanaux, agricoles et professionnels.
      </p>
    </div>
  </section>

<section class="product-anchor-nav" aria-label="Navigation dans la page">
  <div class="container">
    <nav class="anchor-nav">

      <a href="#presentation">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 5h16M4 12h16M4 19h10" />
        </svg>
        <span>Présentation</span>
      </a>

      <a href="#avantages">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m12 3 2.7 5.5 6.1.9-4.4 4.3 1 6.1-5.4-2.9-5.4 2.9 1-6.1-4.4-4.3 6.1-.9L12 3Z" />
        </svg>
        <span>Avantages</span>
      </a>

      <a href="#caracteristiques">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 6h16M7 3v6M4 18h16M17 15v6M4 12h16M12 9v6" />
        </svg>
        <span>Caractéristiques</span>
      </a>

      <a href="#applications">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3 11 12 4l9 7M5 10v10h14V10M9 20v-6h6v6" />
        </svg>
        <span>Applications</span>
      </a>

      <a href="#pourquoi-marin-profils">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 3 4 6v5c0 5 3.4 8.7 8 10 4.6-1.3 8-5 8-10V6l-8-3Z" />
